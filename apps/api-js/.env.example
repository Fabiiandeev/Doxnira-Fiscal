PORT=3333
NODE_ENV=development
DATABASE_URL=postgresql://ns_fiscal_app:change-me-local@localhost:5432/ns_fiscal_cloud?schema=public
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=info
POSTGRES_DB=ns_fiscal_cloud
POSTGRES_USER=ns_fiscal_app
POSTGRES_PASSWORD=change-me-local
JWT_SECRET=change-me-with-at-least-32-characters
JWT_EXPIRES_IN=7d
REDIS_URL=redis://localhost:6379
CERT_ENCRYPTION_KEY=change-me-with-at-least-32-characters
UPLOAD_MAX_SIZE_MB=10
SEFAZ_INTEGRATION_ENABLED=false
SEFAZ_MANIFESTATION_ENABLED=false
CTE_INTEGRATION_ENABLED=false
ALLOW_PRODUCTION_SEFAZ=false
SEFAZ_ENVIRONMENT=homologation
SEFAZ_DIST_DFE_PROD_URL=https://www1.nfe.fazenda.gov.br/NFeDistribuicaoDFe/NFeDistribuicaoDFe.asmx
SEFAZ_DIST_DFE_HOM_URL=https://hom1.nfe.fazenda.gov.br/NFeDistribuicaoDFe/NFeDistribuicaoDFe.asmx
SEFAZ_EVENT_PROD_URL=https://www.nfe.fazenda.gov.br/NFeRecepcaoEvento4/NFeRecepcaoEvento4.asmx
SEFAZ_EVENT_HOM_URL=https://hom1.nfe.fazenda.gov.br/NFeRecepcaoEvento4/NFeRecepcaoEvento4.asmx
