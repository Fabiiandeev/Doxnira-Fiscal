# Copy this file to .env.docker (which is gitignored) and fill the real values.
# Example values below; replace with locally generated secrets.
# Generate:  openssl rand -base64 24   (or any equivalent method)
#
# POSTGRES_PASSWORD MUST be set in .env.docker; docker-compose.yml uses
# ${POSTGRES_PASSWORD:?...} and will refuse to start without it.
POSTGRES_PORT=5432
POSTGRES_DB=ns_fiscal_cloud_test
POSTGRES_USER=ns_fiscal_app
POSTGRES_PASSWORD=replace-me-with-a-locally-generated-secret

# Optional: pin the PostgreSQL major version (default: 16)
POSTGRES_IMAGE_TAG=16-alpine
