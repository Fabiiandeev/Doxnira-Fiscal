generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  OPERATOR
  VIEWER
}

enum Environment {
  production
  homologation
}

enum AllocationStatus {
  NOT_ALLOCATED
  PENDING_CONFIGURATION
  CALCULATED
  CONFIRMED
  APPLIED
  BLOCKED
}

enum AllocationMethod {
  VALUE
  QUANTITY
  WEIGHT
  VOLUME
  MANUAL
}

enum AccountantRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CompanyLinkStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum AccessLevel {
  FULL
  READ_ONLY
  RESTRICTED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(160)
  email        String   @unique @db.VarChar(180)
  passwordHash String   @map("password_hash")
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companies         Company[]
  preferences       UserPreference?
  savedFilters      SavedFilter[]
  documentNotes     DocumentNote[]
  auditLogs         AuditLog[]
  xmlDownloadLogs   XmlDownloadLog[]
  assignedAlerts    Alert[]            @relation("AssignedAlerts")
  clients           Client[]
  nfeValidationRuns NfeValidationRun[]
  nfeDocuments      NfeDocument[]
  cteAllocationsCreated CteAllocation[] @relation("CteAllocationCreatedBy")
  cteAllocationsConfirmed CteAllocation[] @relation("CteAllocationConfirmedBy")
  accountantMemberships AccountantMembership[]
  accountantDocumentReviews AccountantDocumentReview[]
  accountantDocumentNotes AccountantDocumentNote[]
  accountantDocumentTagsCreated AccountantDocumentTag[] @relation("AccountantTagCreator")
  accountantDocumentRequests AccountantDocumentRequest[]
  accountantRequestAssignments AccountantDocumentRequest[] @relation("RequestAssignedTo")
  accountantRequestEvents AccountantDocumentRequestEvent[] @relation("RequestEventActor")

  @@map("users")
}

model Company {
  id                           String      @id @default(uuid()) @db.Uuid
  ownerId                      String      @map("owner_id") @db.Uuid
  legalName                    String      @map("legal_name") @db.VarChar(255)
  tradeName                    String?     @map("trade_name") @db.VarChar(255)
  cnpj                         String      @unique @db.VarChar(14)
  stateRegistration            String?     @map("state_registration") @db.VarChar(40)
  stateRegistrationStatus      String?     @default("PENDENTE_VALIDACAO_SEFAZ") @map("state_registration_status") @db.VarChar(30)
  stateRegistrationSource      String?     @map("state_registration_source") @db.VarChar(50)
  stateRegistrationValidatedAt DateTime?   @map("state_registration_validated_at")
  stateRegistrationFormatted   String?     @map("state_registration_formatted") @db.VarChar(40)
  icmsContributorStatus        String?     @default("PENDENTE_VALIDACAO_SEFAZ") @map("icms_contributor_status") @db.VarChar(30)
  uf                           String?     @db.Char(2)
  city                         String?     @db.VarChar(120)
  taxRegime                    String?     @map("tax_regime") @db.VarChar(60)
  environment                  Environment @default(production)
  status                       String      @default("active") @db.VarChar(30)
  nfeLastNsu                   String      @default("000000000000000") @map("nfe_last_nsu") @db.VarChar(15)
  nfeMaxNsu                    String?     @map("nfe_max_nsu") @db.VarChar(15)
  nfeNextAllowedSyncAt         DateTime?   @map("nfe_next_allowed_sync_at")
  lastSyncAt                   DateTime?   @map("last_sync_at")
  createdAt                    DateTime    @default(now()) @map("created_at")
  updatedAt                    DateTime    @updatedAt @map("updated_at")

  owner                   User                     @relation(fields: [ownerId], references: [id])
  certificates            DigitalCertificate[]
  fiscalDocuments         FiscalDocument[]
  fiscalEvents            FiscalEvent[]
  syncLogs                SyncLog[]
  manifestations          Manifestation[]
  defaultForUsers         UserPreference[]         @relation("DefaultCompany")
  savedFilters            SavedFilter[]
  documentNotes           DocumentNote[]
  documentTags            DocumentTag[]
  alerts                  Alert[]
  auditLogs               AuditLog[]
  xmlDownloadLogs         XmlDownloadLog[]
  transportDocuments      TransportDocument[]
  fiscalDocumentLinks     FiscalDocumentLink[]
  taxSettings             CompanyTaxSetting?
  documentItems           FiscalDocumentItem[]
  monthlyClosings         MonthlyTaxClosing[]
  taxRules                TaxRule[]
  products                Product[]
  clients                 Client[]
  transportadoras         Transportadora[]
  fornecedores            Fornecedor[]
  nfeDocuments            NfeDocument[]
  nfeNumberSequences      NfeNumberSequence[]
  nfeValidationRuns       NfeValidationRun[]
  nfeItems                NfeItem[]
  nfeTotals               NfeTotal[]
  nfeTransport            NfeTransport[]
  nfeBilling              NfeBilling[]
  nfeInstallments         NfeInstallment[]
  nfeObservations         NfeObservation[]
  nfeReferences           NfeReference[]
  nfeValidationResults    NfeValidationResult[]
  nfeValidationIssues     NfeValidationIssue[]
  nfeAutoFixes            NfeAutoFix[]
  nfeTransmissionAttempts NfeTransmissionAttempt[]
  nfeSefazReturns         NfeSefazReturn[]
  nfeAuthorizations       NfeAuthorization[]
  nfeFiles                NfeFile[]
  nfeLogs                 NfeLog[]
  nfeEntries              NfeEntry[]
  nfeEntryItems           NfeEntryItem[]
  nfeEntryProductLinks    NfeEntryProductLink[]
  nfeEntryManifestations  NfeEntryManifestation[]
  nfeEntryEvents          NfeEntryEvent[]
  cteEntries              CteEntry[]
  cteEntryNfeLinks        CteEntryNfeLink[]
  cteAllocations          CteAllocation[]
  cteAllocationDocuments  CteAllocationDocument[]
  cteAllocationItems      CteAllocationItem[]
  cteEntryAuditLogs       CteEntryAuditLog[]
  stockMovements          StockMovement[]
  payables                Payable[]
  fiscalAlerts            FiscalAlert[]
  dfeSyncLogs             DfeSyncLog[]
  accountantLinks         AccountantCompanyLink[]
  accountantAccessGrants  AccountantUserCompanyAccess[]
  accountantDocumentReviews AccountantDocumentReview[]
  accountantNotes         AccountantDocumentNote[]
  accountantTagLinks      AccountantDocumentTagLink[]
  accountantRequests      AccountantDocumentRequest[]
  accountantRequestEvents AccountantDocumentRequestEvent[]

  @@index([ownerId])
  @@map("companies")
}

model DigitalCertificate {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  serialNumber      String?   @map("serial_number") @db.VarChar(120)
  subject           String?
  issuer            String?
  validFrom         DateTime? @map("valid_from")
  validUntil        DateTime? @map("valid_until")
  encryptedFile     Bytes     @map("encrypted_file")
  encryptedPassword String    @map("encrypted_password")
  holderCnpj        String?   @map("holder_cnpj") @db.VarChar(14)
  validatedAt       DateTime? @map("validated_at")
  status            String    @default("active") @db.VarChar(30)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("digital_certificates")
}

model FiscalDocument {
  id                  String    @id @default(uuid()) @db.Uuid
  companyId           String    @map("company_id") @db.Uuid
  documentType        String    @map("document_type") @db.VarChar(30)
  operationDirection  String    @default("UNKNOWN") @map("operation_direction") @db.VarChar(30)
  companyRole         String    @default("OTHER") @map("company_role") @db.VarChar(30)
  invoiceNumber       String?   @map("invoice_number") @db.VarChar(30)
  series              String?   @db.VarChar(10)
  model               String?   @db.VarChar(10)
  accessKey           String?   @map("access_key") @db.VarChar(44)
  nsu                 String?   @db.VarChar(15)
  schemaName          String?   @map("schema_name") @db.VarChar(120)
  status              String?   @db.VarChar(40)
  protocol            String?   @db.VarChar(80)
  manifestationStatus String    @default("PENDING") @map("manifestation_status") @db.VarChar(30)
  issuerCnpj          String?   @map("issuer_cnpj") @db.VarChar(14)
  issuerName          String?   @map("issuer_name") @db.VarChar(255)
  recipientCnpj       String?   @map("recipient_cnpj") @db.VarChar(14)
  recipientName       String?   @map("recipient_name") @db.VarChar(255)
  uf                  String?   @db.Char(2)
  cfop                String?   @db.VarChar(10)
  emissionDate        DateTime? @map("emission_date")
  authorizationDate   DateTime? @map("authorization_date")
  totalAmount         Decimal?  @map("total_amount") @db.Decimal(15, 2)
  productsAmount      Decimal?  @default(0) @map("products_amount") @db.Decimal(15, 2)
  freightAmount       Decimal?  @default(0) @map("freight_amount") @db.Decimal(15, 2)
  discountAmount      Decimal?  @default(0) @map("discount_amount") @db.Decimal(15, 2)
  icmsAmount          Decimal?  @default(0) @map("icms_amount") @db.Decimal(15, 2)
  ipiAmount           Decimal?  @default(0) @map("ipi_amount") @db.Decimal(15, 2)
  pisAmount           Decimal?  @default(0) @map("pis_amount") @db.Decimal(15, 2)
  cofinsAmount        Decimal?  @default(0) @map("cofins_amount") @db.Decimal(15, 2)
  icmsBase            Decimal?  @default(0) @map("icms_base") @db.Decimal(15, 2)
  icmsStAmount        Decimal?  @default(0) @map("icms_st_amount") @db.Decimal(15, 2)
  fcpAmount           Decimal?  @default(0) @map("fcp_amount") @db.Decimal(15, 2)
  otherAmount         Decimal?  @default(0) @map("other_amount") @db.Decimal(15, 2)
  taxAmount           Decimal?  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  xmlStorageKey       String    @map("xml_storage_key")
  xmlHashSha256       String    @map("xml_hash_sha256") @db.VarChar(64)
  rawXmlHash          String?   @map("raw_xml_hash") @db.VarChar(64)
  source              String    @default("MANUAL_IMPORT") @db.VarChar(30)
  rawXml              String?   @map("raw_xml")
  products            Json?
  taxes               Json?
  isSummary           Boolean   @default(false) @map("is_summary")
  isCancelled         Boolean   @default(false) @map("is_cancelled")
  isNewSupplier       Boolean   @default(false) @map("is_new_supplier")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  company        Company                 @relation(fields: [companyId], references: [id])
  events         FiscalEvent[]
  manifestations Manifestation[]
  notes          DocumentNote[]
  tags           DocumentTagLink[]
  alerts         Alert[]
  downloadLogs   XmlDownloadLog[]
  transportLinks FiscalDocumentLink[]    @relation("LinkedNfe")
  items          FiscalDocumentItem[]
  closingItems   MonthlyTaxClosingItem[]
  nfeEntry       NfeEntry?
  fiscalAlerts   FiscalAlert[]
  accountantReviews AccountantDocumentReview[]
  accountantNotes AccountantDocumentNote[]
  accountantTagLinks AccountantDocumentTagLink[]
  accountantRequests AccountantDocumentRequest[]

  @@unique([companyId, nsu])
  @@unique([companyId, accessKey, schemaName])
  @@index([companyId, emissionDate(sort: Desc)])
  @@index([accessKey])
  @@index([issuerCnpj])
  @@index([recipientCnpj])
  @@index([companyId, nsu])
  @@index([companyId, status])
  @@index([companyId, source])
  @@index([companyId, documentType])
  @@index([companyId, operationDirection])
  @@index([companyId, cfop])
  @@index([companyId, isSummary])
  @@index([companyId, isCancelled])
  @@index([companyId, createdAt(sort: Desc)])
  @@map("fiscal_documents")
}

model CompanyTaxSetting {
  id                    String   @id @default(uuid()) @db.Uuid
  companyId             String   @unique @map("company_id") @db.Uuid
  taxRegime             String   @map("tax_regime") @db.VarChar(40)
  calculationRegime     String   @map("calculation_regime") @db.VarChar(30)
  uf                    String   @db.Char(2)
  stateRegistration     String?  @map("state_registration") @db.VarChar(40)
  mainCnae              String?  @map("main_cnae") @db.VarChar(20)
  secondaryCnaes        Json?    @map("secondary_cnaes")
  simplesAnnex          String?  @map("simples_annex") @db.VarChar(20)
  mainActivity          String?  @map("main_activity") @db.VarChar(255)
  isIcmsTaxpayer        Boolean  @default(false) @map("is_icms_taxpayer")
  isIpiTaxpayer         Boolean  @default(false) @map("is_ipi_taxpayer")
  icmsContribType       String?  @map("icms_contrib_type") @db.VarChar(20)
  pisCofinsRegime       String   @map("pis_cofins_regime") @db.VarChar(30)
  accumulatedRevenue    Decimal? @map("accumulated_revenue") @db.Decimal(15, 2)
  providesService       Boolean  @default(false) @map("provides_service")
  sellsMerchandise      Boolean  @default(true) @map("sells_merchandise")
  municipalRegistration String?  @map("municipal_registration") @db.VarChar(40)

  simplesNominalRate    Decimal? @map("simples_nominal_rate") @db.Decimal(5, 2)
  simplesDeductAmount   Decimal? @map("simples_deduct_amount") @db.Decimal(15, 2)
  simplesEffectiveRate  Decimal? @map("simples_effective_rate") @db.Decimal(5, 2)
  simplesIcmsPercent    Decimal? @map("simples_icms_percent") @db.Decimal(5, 2)
  simplesIssPercent     Decimal? @map("simples_iss_percent") @db.Decimal(5, 2)
  simplesCppPercent     Decimal? @map("simples_cpp_percent") @db.Decimal(5, 2)
  simplesFatorR         Decimal? @map("simples_fator_r") @db.Decimal(5, 2)
  simplesRevenue12m     Decimal? @map("simples_revenue_12m") @db.Decimal(15, 2)
  simplesPayroll12m     Decimal? @map("simples_payroll_12m") @db.Decimal(15, 2)
  simplesManualOverride Boolean  @default(false) @map("simples_manual_override")

  presumidoIrpjBase       Decimal? @map("presumido_irpj_base") @db.Decimal(5, 2)
  presumidoCsllBase       Decimal? @map("presumido_csll_base") @db.Decimal(5, 2)
  presumidoPisRate        Decimal? @map("presumido_pis_rate") @db.Decimal(5, 2)
  presumidoCofinsRate     Decimal? @map("presumido_cofins_rate") @db.Decimal(5, 2)
  presumidoIssRate        Decimal? @map("presumido_iss_rate") @db.Decimal(5, 2)
  presumidoIcmsRate       Decimal? @map("presumido_icms_rate") @db.Decimal(5, 2)
  presumidoIpiRate        Decimal? @map("presumido_ipi_rate") @db.Decimal(5, 2)
  presumidoRatPercent     Decimal? @map("presumido_rat_percent") @db.Decimal(5, 2)
  presumidoThirdParty     Decimal? @map("presumido_third_party") @db.Decimal(5, 2)
  presumidoInssPatronal   Decimal? @map("presumido_inss_patronal") @db.Decimal(5, 2)
  presumidoIrpjVencimento String?  @map("presumido_irpj_vencimento") @db.VarChar(20)
  presumidoCsllVencimento String?  @map("presumido_csll_vencimento") @db.VarChar(20)

  realapuracaoPeriod  String?  @map("real_apuracao_period") @db.VarChar(20)
  realPisRate         Decimal? @map("real_pis_rate") @db.Decimal(5, 2)
  realCofinsRate      Decimal? @map("real_cofins_rate") @db.Decimal(5, 2)
  realCreditAllowed   Boolean  @default(false) @map("real_credit_allowed")
  realLalurControl    Boolean  @default(false) @map("real_lalur_control")
  realPrejuizoControl Boolean  @default(false) @map("real_prejuizo_control")
  realIrpjRate        Decimal? @map("real_irpj_rate") @db.Decimal(5, 2)
  realCsllRate        Decimal? @map("real_csll_rate") @db.Decimal(5, 2)

  fiscalConfigComplete Boolean @default(false) @map("fiscal_config_complete")
  crt                  String? @db.VarChar(2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("company_tax_settings")
}

model FiscalDocumentItem {
  id            String   @id @default(uuid()) @db.Uuid
  documentId    String   @map("document_id") @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  itemNumber    Int      @map("item_number")
  productCode   String?  @map("product_code") @db.VarChar(80)
  ean           String?  @db.VarChar(30)
  description   String?  @db.VarChar(255)
  ncm           String?  @db.VarChar(20)
  cfop          String?  @db.VarChar(10)
  cst           String?  @db.VarChar(10)
  csosn         String?  @db.VarChar(10)
  quantity      Decimal? @db.Decimal(15, 4)
  unit          String?  @db.VarChar(10)
  unitValue     Decimal? @map("unit_value") @db.Decimal(15, 4)
  totalValue    Decimal? @map("total_value") @db.Decimal(15, 2)
  discountValue Decimal? @default(0) @map("discount_value") @db.Decimal(15, 2)
  icmsBase      Decimal? @default(0) @map("icms_base") @db.Decimal(15, 2)
  icmsRate      Decimal? @default(0) @map("icms_rate") @db.Decimal(8, 4)
  icmsAmount    Decimal? @default(0) @map("icms_amount") @db.Decimal(15, 2)
  ipiBase       Decimal? @default(0) @map("ipi_base") @db.Decimal(15, 2)
  ipiRate       Decimal? @default(0) @map("ipi_rate") @db.Decimal(8, 4)
  ipiAmount     Decimal? @default(0) @map("ipi_amount") @db.Decimal(15, 2)
  pisBase       Decimal? @default(0) @map("pis_base") @db.Decimal(15, 2)
  pisRate       Decimal? @default(0) @map("pis_rate") @db.Decimal(8, 4)
  pisAmount     Decimal? @default(0) @map("pis_amount") @db.Decimal(15, 2)
  cofinsBase    Decimal? @default(0) @map("cofins_base") @db.Decimal(15, 2)
  cofinsRate    Decimal? @default(0) @map("cofins_rate") @db.Decimal(8, 4)
  cofinsAmount  Decimal? @default(0) @map("cofins_amount") @db.Decimal(15, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  document      FiscalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  company       Company        @relation(fields: [companyId], references: [id])
  nfeEntryItems NfeEntryItem[]

  @@unique([documentId, itemNumber])
  @@index([companyId])
  @@index([documentId])
  @@index([cfop])
  @@index([ncm])
  @@map("fiscal_document_items")
}

model MonthlyTaxClosing {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  periodYear        Int       @map("period_year")
  periodMonth       Int       @map("period_month")
  status            String    @default("DRAFT") @db.VarChar(30)
  officeId          String?   @map("office_id") @db.Uuid
  sourceSnapshotAt  DateTime? @map("source_snapshot_at")
  taxSettingsSnapshot Json?   @map("tax_settings_snapshot_json")
  eligibleDocuments Int       @default(0) @map("eligible_documents")
  blockedDocuments  Int       @default(0) @map("blocked_documents")
  pendingCount      Int       @default(0) @map("pending_count")
  createdByUserId   String?   @map("created_by_user_id") @db.Uuid
  approvedByUserId  String?   @map("approved_by_user_id") @db.Uuid
  reopenedByUserId  String?   @map("reopened_by_user_id") @db.Uuid
  reopenedAt        DateTime? @map("reopened_at")
  approvalNote      String?   @map("approval_note")
  reopenReason      String?   @map("reopen_reason")
  inboundTotal      Decimal   @default(0) @map("inbound_total") @db.Decimal(15, 2)
  outboundTotal     Decimal   @default(0) @map("outbound_total") @db.Decimal(15, 2)
  freightTotal      Decimal   @default(0) @map("freight_total") @db.Decimal(15, 2)
  icmsTotal         Decimal   @default(0) @map("icms_total") @db.Decimal(15, 2)
  ipiTotal          Decimal   @default(0) @map("ipi_total") @db.Decimal(15, 2)
  pisTotal          Decimal   @default(0) @map("pis_total") @db.Decimal(15, 2)
  cofinsTotal       Decimal   @default(0) @map("cofins_total") @db.Decimal(15, 2)
  estimatedTaxTotal Decimal   @default(0) @map("estimated_tax_total") @db.Decimal(15, 2)
  includedDocuments Int       @default(0) @map("included_documents")
  ignoredDocuments  Int       @default(0) @map("ignored_documents")
  snapshot          Json?
  approvedAt        DateTime? @map("approved_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company  Company                    @relation(fields: [companyId], references: [id])
  items    MonthlyTaxClosingItem[]
  warnings MonthlyTaxClosingWarning[]
  events   MonthlyTaxClosingEvent[]
  fiscalBookPreparations FiscalBookPreparation[]

  @@unique([companyId, periodYear, periodMonth])
  @@index([companyId, periodYear, periodMonth])
  @@index([status])
  @@index([companyId, periodYear, periodMonth, status])
  @@map("monthly_tax_closings")
}

model FiscalBookPreparation {
  id String @id @default(uuid()) @db.Uuid
  companyId String @map("company_id") @db.Uuid
  officeId String? @map("office_id") @db.Uuid
  monthlyTaxClosingId String @map("monthly_tax_closing_id") @db.Uuid
  periodYear Int @map("period_year")
  periodMonth Int @map("period_month")
  status String @default("DRAFT") @db.VarChar(30)
  snapshotHash String? @map("snapshot_hash") @db.VarChar(64)
  sourceClosingApprovedAt DateTime? @map("source_closing_approved_at")
  generatedAt DateTime? @map("generated_at")
  generatedByUserId String? @map("generated_by_user_id") @db.Uuid
  invalidatedAt DateTime? @map("invalidated_at")
  invalidatedReason String? @map("invalidated_reason")
  documentsCount Int @default(0) @map("documents_count")
  itemsCount Int @default(0) @map("items_count")
  issuesCount Int @default(0) @map("issues_count")
  blockingIssuesCount Int @default(0) @map("blocking_issues_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  closing MonthlyTaxClosing @relation(fields: [monthlyTaxClosingId], references: [id], onDelete: Cascade)
  documents FiscalBookPreparationDocument[]
  issues FiscalBookIssue[]
  @@unique([monthlyTaxClosingId])
  @@index([companyId, periodYear, periodMonth, status])
  @@map("fiscal_book_preparations")
}

model FiscalBookPreparationDocument {
  id String @id @default(uuid()) @db.Uuid
  preparationId String @map("preparation_id") @db.Uuid
  companyId String @map("company_id") @db.Uuid
  sourceType String @map("source_type") @db.VarChar(10)
  sourceDocumentId String? @map("source_document_id") @db.Uuid
  operationGroup String @map("operation_group") @db.VarChar(30)
  accessKey String? @map("access_key") @db.VarChar(44)
  model String? @db.VarChar(10)
  series String? @db.VarChar(10)
  number String? @db.VarChar(30)
  emissionDate DateTime? @map("emission_date")
  participantDocument String? @map("participant_document") @db.VarChar(20)
  participantName String? @map("participant_name")
  cfop String? @db.VarChar(10)
  totalAmount Decimal? @map("total_amount") @db.Decimal(15,2)
  icmsAmount Decimal? @map("icms_amount") @db.Decimal(15,2)
  ipiAmount Decimal? @map("ipi_amount") @db.Decimal(15,2)
  pisAmount Decimal? @map("pis_amount") @db.Decimal(15,2)
  cofinsAmount Decimal? @map("cofins_amount") @db.Decimal(15,2)
  freightAmount Decimal? @map("freight_amount") @db.Decimal(15,2)
  sourceOrigin String? @map("source_origin") @db.VarChar(30)
  preparation FiscalBookPreparation @relation(fields: [preparationId], references: [id], onDelete: Cascade)
  items FiscalBookPreparationItem[]
  @@unique([preparationId, sourceDocumentId])
  @@index([preparationId, operationGroup])
  @@map("fiscal_book_preparation_documents")
}

model FiscalBookPreparationItem {
  id String @id @default(uuid()) @db.Uuid
  preparationDocumentId String @map("preparation_document_id") @db.Uuid
  itemNumber Int @map("item_number")
  productCode String? @map("product_code")
  description String?
  ncm String? @db.VarChar(20)
