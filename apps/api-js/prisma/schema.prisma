  respondedAt         DateTime? @map("responded_at")
  resolvedAt          DateTime? @map("resolved_at")
  cancelledAt         DateTime? @map("cancelled_at")
  reopenedAt          DateTime? @map("reopened_at")
  resolvedByUserId    String?  @map("resolved_by_user_id") @db.Uuid
  cancelledByUserId   String?  @map("cancelled_by_user_id") @db.Uuid
  lastResponseAt      DateTime? @map("last_response_at")
  lastResponseByUserId String? @map("last_response_by_user_id") @db.Uuid
  resolutionNote      String?  @map("resolution_note") @db.Text
