{
  "name": "@ns-fiscal/api-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "check": "node scripts/check-syntax.js",
    "lint": "node scripts/check-syntax.js",
    "build": "node scripts/check-syntax.js",
    "test": "node --env-file=.env.test --test test/unit/nfe-entry-rules.unit.test.js test/unit/cte-allocation-rules.unit.test.js test/unit/test-database-safety.unit.test.js test/unit/accountant-permissions.unit.test.js test/unit/accountant-documents-filters.unit.test.js test/integration/incoming-nfe.integration.test.js",
    "test:unit": "node --env-file=.env.test --test test/unit/nfe-entry-rules.unit.test.js test/unit/cte-allocation-rules.unit.test.js test/unit/test-database-safety.unit.test.js",
    "test:cte-allocation": "node --env-file=.env.test --test test/unit/cte-allocation-rules.unit.test.js test/unit/cte-allocation-service.unit.test.js",
    "test:integration": "node --env-file=.env.test --test test/integration/incoming-nfe.integration.test.js",
    "test:incoming-nfe": "node --env-file=.env.test --test test/integration/incoming-nfe.integration.test.js",
    "test:http": "node --env-file=.env.test --test test/e2e/incoming-nfe.e2e.test.js",
    "test:http:cte-entry": "node --env-file=.env.test --test test/e2e/cte-entry-allocation.e2e.test.js",
    "test:e2e": "node --env-file=.env.test --test test/e2e/incoming-nfe.e2e.test.js",
    "test:e2e:incoming-nfe": "node --env-file=.env.test --test test/e2e/incoming-nfe.e2e.test.js",
    "test:coverage": "node --env-file=.env.test --test --experimental-test-coverage test/unit/nfe-entry-rules.unit.test.js test/unit/test-database-safety.unit.test.js test/integration/incoming-nfe.integration.test.js",
    "test:db:migrate": "node scripts/test-db-migrate.mjs",
    "audit:external-migrations": "node scripts/audit-external-migrations.mjs",
    "prisma:generate": "prisma generate --config prisma.config.js",
    "prisma:validate": "prisma validate --config prisma.config.js",
    "prisma:migrate": "prisma migrate dev --config prisma.config.js",
    "prisma:deploy": "prisma migrate deploy --config prisma.config.js",
    "prisma:seed": "prisma db seed --config prisma.config.js",
    "db:seed": "tsx prisma/seed.ts",
    "worker:sync": "node src/modules/sync/sync.worker.js",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@xmldom/xmldom": "0.8.11",
    "bcryptjs": "3.0.2",
    "bullmq": "5.65.1",
    "compression": "1.8.1",
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "fast-xml-parser": "5.2.5",
    "helmet": "8.1.0",
    "ioredis": "5.8.2",
    "jsonwebtoken": "9.0.2",
    "multer": "2.0.2",
    "node-forge": "1.3.1",
    "pg": "8.16.3",
    "pino": "10.1.0",
    "pino-http": "11.0.0",
    "xml-crypto": "6.1.2",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "tsx": "4.19.4"
  }
}
