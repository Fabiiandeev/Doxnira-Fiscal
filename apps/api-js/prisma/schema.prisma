generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  OPERATOR
  VIEWER
}

enum Environment {
  production
  homologation
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(160)
  email        String   @unique @db.VarChar(180)
  passwordHash String   @map("password_hash")
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companies       Company[]
  preferences     UserPreference?
  savedFilters    SavedFilter[]
  documentNotes   DocumentNote[]
  auditLogs       AuditLog[]
  xmlDownloadLogs XmlDownloadLog[]
  assignedAlerts  Alert[]          @relation("AssignedAlerts")
  clients         Client[]

  @@map("users")
}

model Company {
  id                   String      @id @default(uuid()) @db.Uuid
  ownerId              String      @map("owner_id") @db.Uuid
  legalName            String      @map("legal_name") @db.VarChar(255)
  tradeName            String?     @map("trade_name") @db.VarChar(255)
  cnpj                 String      @unique @db.VarChar(14)
  stateRegistration    String?     @map("state_registration") @db.VarChar(40)
  stateRegistrationStatus String? @map("state_registration_status") @db.VarChar(30) @default("PENDENTE_VALIDACAO_SEFAZ")
  stateRegistrationSource String? @map("state_registration_source") @db.VarChar(50)
  stateRegistrationValidatedAt DateTime? @map("state_registration_validated_at")
  stateRegistrationFormatted String? @map("state_registration_formatted") @db.VarChar(40)
  icmsContributorStatus String? @map("icms_contributor_status") @db.VarChar(30) @default("PENDENTE_VALIDACAO_SEFAZ")
  uf                   String?     @db.Char(2)
  city                 String?     @db.VarChar(120)
  taxRegime            String?     @map("tax_regime") @db.VarChar(60)
  environment          Environment @default(production)
  status               String      @default("active") @db.VarChar(30)
  nfeLastNsu           String      @default("000000000000000") @map("nfe_last_nsu") @db.VarChar(15)
  nfeMaxNsu            String?     @map("nfe_max_nsu") @db.VarChar(15)
  nfeNextAllowedSyncAt DateTime?   @map("nfe_next_allowed_sync_at")
  lastSyncAt           DateTime?   @map("last_sync_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  owner            User                 @relation(fields: [ownerId], references: [id])
  certificates     DigitalCertificate[]
  fiscalDocuments  FiscalDocument[]
  fiscalEvents     FiscalEvent[]
  syncLogs         SyncLog[]
  manifestations   Manifestation[]
  defaultForUsers  UserPreference[]     @relation("DefaultCompany")
  savedFilters     SavedFilter[]
  documentNotes    DocumentNote[]
  documentTags     DocumentTag[]
  alerts           Alert[]
  auditLogs        AuditLog[]
  xmlDownloadLogs  XmlDownloadLog[]
  transportDocuments TransportDocument[]
  fiscalDocumentLinks FiscalDocumentLink[]
  taxSettings       CompanyTaxSetting?
  documentItems     FiscalDocumentItem[]
  monthlyClosings   MonthlyTaxClosing[]
  taxRules          TaxRule[]
  products          Product[]

  @@index([ownerId])
  @@map("companies")
}

model DigitalCertificate {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  serialNumber      String?   @map("serial_number") @db.VarChar(120)
  subject           String?
  issuer            String?
  validFrom         DateTime? @map("valid_from")
  validUntil        DateTime? @map("valid_until")
  encryptedFile     Bytes     @map("encrypted_file")
  encryptedPassword String    @map("encrypted_password")
  holderCnpj        String?   @map("holder_cnpj") @db.VarChar(14)
  validatedAt       DateTime? @map("validated_at")
  status            String    @default("active") @db.VarChar(30)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("digital_certificates")
}

model FiscalDocument {
  id                String    @id @default(uuid()) @db.Uuid
  companyId         String    @map("company_id") @db.Uuid
  documentType      String    @map("document_type") @db.VarChar(30)
  operationDirection String   @default("UNKNOWN") @map("operation_direction") @db.VarChar(30)
  companyRole       String    @default("OTHER") @map("company_role") @db.VarChar(30)
  invoiceNumber     String?   @map("invoice_number") @db.VarChar(30)
  series            String?   @db.VarChar(10)
  model             String?   @db.VarChar(10)
  accessKey         String?   @map("access_key") @db.VarChar(44)
  nsu               String?   @db.VarChar(15)
  schemaName        String?   @map("schema_name") @db.VarChar(120)
  status            String?   @db.VarChar(40)
  protocol          String?   @db.VarChar(80)
  manifestationStatus String  @default("PENDING") @map("manifestation_status") @db.VarChar(30)
  issuerCnpj        String?   @map("issuer_cnpj") @db.VarChar(14)
  issuerName        String?   @map("issuer_name") @db.VarChar(255)
  recipientCnpj     String?   @map("recipient_cnpj") @db.VarChar(14)
  recipientName     String?   @map("recipient_name") @db.VarChar(255)
  uf                String?   @db.Char(2)
  cfop              String?   @db.VarChar(10)
  emissionDate      DateTime? @map("emission_date")
  authorizationDate DateTime? @map("authorization_date")
  totalAmount       Decimal?  @map("total_amount") @db.Decimal(15, 2)
  productsAmount    Decimal?  @default(0) @map("products_amount") @db.Decimal(15, 2)
  freightAmount     Decimal?  @default(0) @map("freight_amount") @db.Decimal(15, 2)
  discountAmount    Decimal?  @default(0) @map("discount_amount") @db.Decimal(15, 2)
  icmsAmount        Decimal?  @default(0) @map("icms_amount") @db.Decimal(15, 2)
  ipiAmount         Decimal?  @default(0) @map("ipi_amount") @db.Decimal(15, 2)
  pisAmount         Decimal?  @default(0) @map("pis_amount") @db.Decimal(15, 2)
  cofinsAmount      Decimal?  @default(0) @map("cofins_amount") @db.Decimal(15, 2)
  icmsBase          Decimal?  @default(0) @map("icms_base") @db.Decimal(15, 2)
  icmsStAmount      Decimal?  @default(0) @map("icms_st_amount") @db.Decimal(15, 2)
  fcpAmount         Decimal?  @default(0) @map("fcp_amount") @db.Decimal(15, 2)
  otherAmount       Decimal?  @default(0) @map("other_amount") @db.Decimal(15, 2)
  taxAmount         Decimal?  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  xmlStorageKey     String    @map("xml_storage_key")
  xmlHashSha256     String    @map("xml_hash_sha256") @db.VarChar(64)
  rawXmlHash        String?   @map("raw_xml_hash") @db.VarChar(64)
  source            String    @default("MANUAL_IMPORT") @db.VarChar(30)
  rawXml            String?   @map("raw_xml")
  products          Json?
  taxes             Json?
  isSummary         Boolean   @default(false) @map("is_summary")
  isCancelled       Boolean   @default(false) @map("is_cancelled")
  isNewSupplier     Boolean   @default(false) @map("is_new_supplier")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company         Company           @relation(fields: [companyId], references: [id])
  events          FiscalEvent[]
  manifestations Manifestation[]
  notes           DocumentNote[]
  tags            DocumentTagLink[]
  alerts          Alert[]
  downloadLogs    XmlDownloadLog[]
  transportLinks  FiscalDocumentLink[] @relation("LinkedNfe")
  items           FiscalDocumentItem[]
  closingItems    MonthlyTaxClosingItem[]

  @@unique([companyId, nsu])
  @@unique([companyId, accessKey, schemaName])
  @@index([companyId, emissionDate(sort: Desc)])
  @@index([accessKey])
  @@index([issuerCnpj])
  @@index([recipientCnpj])
  @@index([companyId, nsu])
  @@index([companyId, status])
  @@index([companyId, source])
  @@index([companyId, documentType])
  @@index([companyId, operationDirection])
  @@index([companyId, cfop])
  @@index([companyId, isSummary])
  @@index([companyId, isCancelled])
  @@index([companyId, createdAt(sort: Desc)])
  @@map("fiscal_documents")
}

model CompanyTaxSetting {
  id                 String   @id @default(uuid()) @db.Uuid
  companyId          String   @unique @map("company_id") @db.Uuid
  taxRegime          String   @map("tax_regime") @db.VarChar(40)
  calculationRegime  String   @map("calculation_regime") @db.VarChar(30)
  uf                 String   @db.Char(2)
  stateRegistration  String?  @map("state_registration") @db.VarChar(40)
  mainCnae           String?  @map("main_cnae") @db.VarChar(20)
  simplesAnnex       String?  @map("simples_annex") @db.VarChar(20)
  mainActivity       String?  @map("main_activity") @db.VarChar(255)
  isIcmsTaxpayer     Boolean  @default(false) @map("is_icms_taxpayer")
  isIpiTaxpayer      Boolean  @default(false) @map("is_ipi_taxpayer")
  pisCofinsRegime    String   @map("pis_cofins_regime") @db.VarChar(30)
  accumulatedRevenue Decimal? @map("accumulated_revenue") @db.Decimal(15, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("company_tax_settings")
}

model FiscalDocumentItem {
  id            String   @id @default(uuid()) @db.Uuid
  documentId    String   @map("document_id") @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  itemNumber    Int      @map("item_number")
  productCode   String?  @map("product_code") @db.VarChar(80)
  ean           String?  @db.VarChar(30)
  description   String?  @db.VarChar(255)
  ncm           String?  @db.VarChar(20)
  cfop          String?  @db.VarChar(10)
  cst           String?  @db.VarChar(10)
  csosn         String?  @db.VarChar(10)
  quantity      Decimal? @db.Decimal(15, 4)
  unit          String?  @db.VarChar(10)
  unitValue     Decimal? @map("unit_value") @db.Decimal(15, 4)
  totalValue    Decimal? @map("total_value") @db.Decimal(15, 2)
  discountValue Decimal? @default(0) @map("discount_value") @db.Decimal(15, 2)
  icmsBase      Decimal? @default(0) @map("icms_base") @db.Decimal(15, 2)
  icmsRate      Decimal? @default(0) @map("icms_rate") @db.Decimal(8, 4)
  icmsAmount    Decimal? @default(0) @map("icms_amount") @db.Decimal(15, 2)
  ipiBase       Decimal? @default(0) @map("ipi_base") @db.Decimal(15, 2)
  ipiRate       Decimal? @default(0) @map("ipi_rate") @db.Decimal(8, 4)
  ipiAmount     Decimal? @default(0) @map("ipi_amount") @db.Decimal(15, 2)
  pisBase       Decimal? @default(0) @map("pis_base") @db.Decimal(15, 2)
  pisRate       Decimal? @default(0) @map("pis_rate") @db.Decimal(8, 4)
  pisAmount     Decimal? @default(0) @map("pis_amount") @db.Decimal(15, 2)
  cofinsBase    Decimal? @default(0) @map("cofins_base") @db.Decimal(15, 2)
  cofinsRate    Decimal? @default(0) @map("cofins_rate") @db.Decimal(8, 4)
  cofinsAmount  Decimal? @default(0) @map("cofins_amount") @db.Decimal(15, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  document FiscalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  company  Company        @relation(fields: [companyId], references: [id])

  @@unique([documentId, itemNumber])
  @@index([companyId])
  @@index([documentId])
  @@index([cfop])
  @@index([ncm])
  @@map("fiscal_document_items")
}

model MonthlyTaxClosing {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  periodYear         Int       @map("period_year")
  periodMonth        Int       @map("period_month")
  status             String    @default("DRAFT") @db.VarChar(30)
  inboundTotal       Decimal   @default(0) @map("inbound_total") @db.Decimal(15, 2)
  outboundTotal      Decimal   @default(0) @map("outbound_total") @db.Decimal(15, 2)
  freightTotal       Decimal   @default(0) @map("freight_total") @db.Decimal(15, 2)
  icmsTotal          Decimal   @default(0) @map("icms_total") @db.Decimal(15, 2)
  ipiTotal           Decimal   @default(0) @map("ipi_total") @db.Decimal(15, 2)
  pisTotal           Decimal   @default(0) @map("pis_total") @db.Decimal(15, 2)
  cofinsTotal        Decimal   @default(0) @map("cofins_total") @db.Decimal(15, 2)
  estimatedTaxTotal  Decimal   @default(0) @map("estimated_tax_total") @db.Decimal(15, 2)
  includedDocuments  Int       @default(0) @map("included_documents")
  ignoredDocuments   Int       @default(0) @map("ignored_documents")
  snapshot           Json?
  approvedAt         DateTime? @map("approved_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  company  Company                    @relation(fields: [companyId], references: [id])
  items    MonthlyTaxClosingItem[]
  warnings MonthlyTaxClosingWarning[]

  @@unique([companyId, periodYear, periodMonth])
  @@index([companyId, periodYear, periodMonth])
  @@index([status])
  @@map("monthly_tax_closings")
}

model MonthlyTaxClosingItem {
  id             String   @id @default(uuid()) @db.Uuid
  closingId      String   @map("closing_id") @db.Uuid
  documentId     String?  @map("document_id") @db.Uuid
  category       String   @db.VarChar(30)
  source         String   @db.VarChar(30)
  accessKey      String?  @map("access_key") @db.VarChar(44)
  amount         Decimal  @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal  @default(0) @map("tax_amount") @db.Decimal(15, 2)
  snapshot       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  closing  MonthlyTaxClosing @relation(fields: [closingId], references: [id], onDelete: Cascade)
  document FiscalDocument?   @relation(fields: [documentId], references: [id])

  @@index([closingId, category])
  @@index([documentId])
  @@map("monthly_tax_closing_items")
}

model MonthlyTaxClosingWarning {
  id        String   @id @default(uuid()) @db.Uuid
  closingId String   @map("closing_id") @db.Uuid
  code      String   @db.VarChar(80)
  severity  String   @db.VarChar(20)
  message   String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  closing MonthlyTaxClosing @relation(fields: [closingId], references: [id], onDelete: Cascade)

  @@index([closingId, severity])
  @@map("monthly_tax_closing_warnings")
}

model TaxRule {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  taxRegime          String    @map("tax_regime") @db.VarChar(40)
  uf                 String?   @db.Char(2)
  cfop               String?   @db.VarChar(10)
  ncm                String?   @db.VarChar(20)
  cst                String?   @db.VarChar(10)
  csosn              String?   @db.VarChar(10)
  taxType            String    @map("tax_type") @db.VarChar(30)
  operationDirection String?   @map("operation_direction") @db.VarChar(30)
  rate               Decimal   @db.Decimal(8, 4)
  creditAllowed      Boolean   @default(false) @map("credit_allowed")
  debitAllowed       Boolean   @default(false) @map("debit_allowed")
  effectiveFrom      DateTime  @map("effective_from")
  effectiveUntil     DateTime? @map("effective_until")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, taxType])
  @@index([companyId, cfop, ncm])
  @@index([effectiveFrom, effectiveUntil])
  @@map("tax_rules")
}

model TransportDocument {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  accessKey      String    @map("access_key") @db.VarChar(44)
  number         String?   @db.VarChar(30)
  series         String?   @db.VarChar(10)
  emissionDate   DateTime? @map("emission_date")
  issuerCnpj     String?   @map("issuer_cnpj") @db.VarChar(14)
  issuerName     String?   @map("issuer_name") @db.VarChar(255)
  recipientCnpj  String?   @map("recipient_cnpj") @db.VarChar(14)
  recipientName  String?   @map("recipient_name") @db.VarChar(255)
  totalAmount    Decimal?  @map("total_amount") @db.Decimal(15, 2)
  status         String?   @db.VarChar(40)
  xmlStorageKey  String    @map("xml_storage_key")
  rawXmlHash     String    @map("raw_xml_hash") @db.VarChar(64)
  rawXml         String?   @map("raw_xml")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company Company               @relation(fields: [companyId], references: [id])
  nfeLinks FiscalDocumentLink[] @relation("LinkedCte")

  @@unique([companyId, accessKey])
  @@index([companyId, emissionDate(sort: Desc)])
  @@index([issuerCnpj])
  @@index([recipientCnpj])
  @@index([createdAt(sort: Desc)])
  @@map("transport_documents")
}

model FiscalDocumentLink {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  nfeDocumentId String?  @map("nfe_document_id") @db.Uuid
  cteDocumentId String   @map("cte_document_id") @db.Uuid
  nfeAccessKey  String   @map("nfe_access_key") @db.VarChar(44)
  cteAccessKey  String   @map("cte_access_key") @db.VarChar(44)
  linkType      String   @default("NFE_CTE") @map("link_type") @db.VarChar(30)
  source        String   @default("CTE_XML") @db.VarChar(30)
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company            @relation(fields: [companyId], references: [id])
  nfeDocument FiscalDocument?    @relation("LinkedNfe", fields: [nfeDocumentId], references: [id])
  cteDocument TransportDocument  @relation("LinkedCte", fields: [cteDocumentId], references: [id])

  @@unique([companyId, nfeAccessKey, cteAccessKey, linkType])
  @@index([companyId])
  @@index([nfeAccessKey])
  @@index([cteAccessKey])
  @@index([nfeDocumentId])
  @@index([cteDocumentId])
  @@index([linkType])
  @@index([createdAt(sort: Desc)])
  @@map("fiscal_document_links")
}

model FiscalEvent {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  fiscalDocumentId String?   @map("fiscal_document_id") @db.Uuid
  accessKey        String?   @map("access_key") @db.VarChar(44)
  eventType        String?   @map("event_type") @db.VarChar(80)
  eventSequence    Int?      @map("event_sequence")
  protocol         String?   @db.VarChar(80)
  eventDate        DateTime? @map("event_date")
  nsu              String?   @db.VarChar(15)
  schemaName       String?   @map("schema_name") @db.VarChar(120)
  xmlStorageKey    String    @map("xml_storage_key")
  xmlHashSha256    String    @map("xml_hash_sha256") @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at")

  company        Company         @relation(fields: [companyId], references: [id])
  fiscalDocument FiscalDocument? @relation(fields: [fiscalDocumentId], references: [id])

  @@index([companyId, accessKey])
  @@map("fiscal_events")
}

model SyncLog {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  service        String    @db.VarChar(60)
  requestType    String    @map("request_type") @db.VarChar(40)
  requestNsu     String?   @map("request_nsu") @db.VarChar(15)
  responseUltNsu String?   @map("response_ult_nsu") @db.VarChar(15)
  responseMaxNsu String?   @map("response_max_nsu") @db.VarChar(15)
  cstat          String?   @db.VarChar(10)
  xmotivo        String?
  documentsCount Int       @default(0) @map("documents_count")
  documentsReceived Int    @default(0) @map("documents_received")
  documentsSaved Int       @default(0) @map("documents_saved")
  mode           String    @default("mock") @db.VarChar(20)
  environment    String?   @db.VarChar(20)
  status         String    @db.VarChar(30)
  jobId          String?   @map("job_id") @db.VarChar(120)
  errorMessage   String?   @map("error_message")
  startedAt      DateTime  @map("started_at")
  finishedAt     DateTime? @map("finished_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, startedAt(sort: Desc)])
  @@map("sync_logs")
}

model Manifestation {
  id                 String   @id @default(uuid()) @db.Uuid
  companyId          String   @map("company_id") @db.Uuid
  fiscalDocumentId   String?  @map("fiscal_document_id") @db.Uuid
  accessKey          String   @map("access_key") @db.VarChar(44)
  eventType          String   @map("event_type") @db.VarChar(30)
  justification      String?
  protocol           String?  @db.VarChar(80)
  status             String   @db.VarChar(30)
  responseStorageKey String?  @map("response_xml_storage_key")
  requestXmlSanitized String? @map("request_xml_sanitized")
  responseXmlSanitized String? @map("response_xml_sanitized")
  createdAt          DateTime @default(now()) @map("created_at")

  company        Company         @relation(fields: [companyId], references: [id])
  fiscalDocument FiscalDocument? @relation(fields: [fiscalDocumentId], references: [id])

  @@index([companyId, createdAt(sort: Desc)])
  @@map("manifestations")
}

model UserPreference {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  theme            String   @default("light") @db.VarChar(20)
  accentColor      String?  @default("#E8FF5A") @map("accent_color") @db.VarChar(20)
  defaultCompanyId String?  @map("default_company_id") @db.Uuid
  dashboardLayout  Json?    @map("dashboard_layout")
  tableDensity     String?  @default("comfortable") @map("table_density") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id])
  defaultCompany Company? @relation("DefaultCompany", fields: [defaultCompanyId], references: [id])

  @@map("user_preferences")
}

model SavedFilter {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String?  @map("company_id") @db.Uuid
  name      String   @db.VarChar(120)
  module    String   @db.VarChar(60)
  filters   Json
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([userId, module])
  @@map("saved_filters")
}

model DocumentNote {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @map("company_id") @db.Uuid
  fiscalDocumentId String   @map("fiscal_document_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  note             String
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company        Company        @relation(fields: [companyId], references: [id])
  fiscalDocument FiscalDocument @relation(fields: [fiscalDocumentId], references: [id])
  user           User           @relation(fields: [userId], references: [id])

  @@index([fiscalDocumentId, createdAt(sort: Desc)])
  @@map("document_notes")
}

model DocumentTag {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String   @db.VarChar(80)
  color     String?  @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  company Company           @relation(fields: [companyId], references: [id])
  links   DocumentTagLink[]

  @@unique([companyId, name])
  @@map("document_tags")
}

model DocumentTagLink {
  fiscalDocumentId String   @map("fiscal_document_id") @db.Uuid
  tagId            String   @map("tag_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  fiscalDocument FiscalDocument @relation(fields: [fiscalDocumentId], references: [id])
  tag            DocumentTag    @relation(fields: [tagId], references: [id])

  @@id([fiscalDocumentId, tagId])
  @@map("document_tag_links")
}

model Alert {
  id               String    @id @default(uuid()) @db.Uuid
  companyId        String    @map("company_id") @db.Uuid
  fiscalDocumentId String?   @map("fiscal_document_id") @db.Uuid
  type             String    @db.VarChar(80)
  severity         String    @db.VarChar(20)
  title            String    @db.VarChar(180)
  message          String
  status           String    @default("open") @db.VarChar(30)
  assignedToId     String?   @map("assigned_to") @db.Uuid
  readAt            DateTime? @map("read_at")
  resolvedAt       DateTime? @map("resolved_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  company        Company         @relation(fields: [companyId], references: [id])
  fiscalDocument FiscalDocument? @relation(fields: [fiscalDocumentId], references: [id])
  assignedTo     User?           @relation("AssignedAlerts", fields: [assignedToId], references: [id])

  @@index([companyId, status, createdAt(sort: Desc)])
  @@map("alerts")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String?  @map("company_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(120)
  entityType String?  @map("entity_type") @db.VarChar(80)
  entityId   String?  @map("entity_id") @db.Uuid
  ipAddress  String?  @map("ip_address") @db.VarChar(80)
  userAgent  String?  @map("user_agent")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model XmlDownloadLog {
  id               String   @id @default(uuid()) @db.Uuid
  companyId        String   @map("company_id") @db.Uuid
  fiscalDocumentId String   @map("fiscal_document_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  downloadedAt     DateTime @default(now()) @map("downloaded_at")
  ipAddress        String?  @map("ip_address") @db.VarChar(80)

  company        Company        @relation(fields: [companyId], references: [id])
  fiscalDocument FiscalDocument @relation(fields: [fiscalDocumentId], references: [id])
  user           User           @relation(fields: [userId], references: [id])

  @@index([fiscalDocumentId, downloadedAt(sort: Desc)])
  @@map("xml_download_logs")
}

model Client {
  // ID única - gerada automaticamente como UUID
  id                  String    @id @default(uuid()) @db.Uuid

  // Referência ao usuário que criou o cliente
  ownerId             String    @map("owner_id") @db.Uuid

  // Tipo de pessoa: "PJ" (Pessoa Jurídica) ou "PF" (Pessoa Física)
  tipoPessoa          String    @map("tipo_pessoa") @db.VarChar(2)

  // Nomes (depende do tipo de pessoa)
  nome                String?   @db.VarChar(255)           // Para PF
  razaoSocial         String?   @map("razao_social") @db.VarChar(255)    // Para PJ
  nomeFantasia        String?   @map("nome_fantasia") @db.VarChar(255)   // Para PJ

  // Documentos únicos (podem ser null quando não aplicável)
  cpf                 String?   @unique @db.VarChar(11)
  cnpj                String?   @unique @db.VarChar(14)

  // Informações fiscais
  inscricaoEstadual   String?   @map("inscricao_estadual") @db.VarChar(40)
  inscricaoMunicipal  String?   @map("inscricao_municipal") @db.VarChar(40)
  regimeTributario    String?   @map("regime_tributario") @db.VarChar(60)
  cnae                String?   @db.VarChar(20)
  atividadeEconomica   String?  @map("atividade_economica") @db.VarChar(255)
  naturezaJuridica    String?   @map("natureza_juridica") @db.VarChar(100)
  situacaoCadastral   String?   @map("situacao_cadastral") @db.VarChar(100)

  // Documentos PF
  rg                  String?   @db.VarChar(30)
  dataNascimento      DateTime? @map("data_nascimento")

  // Endereço
  cep                 String?   @db.VarChar(8)
  logradouro          String?   @db.VarChar(255)
  numero              String?   @db.VarChar(20)
  complemento         String?   @db.VarChar(255)
  bairro              String?   @db.VarChar(100)
  municipio           String?   @db.VarChar(120)
  uf                  String?   @db.Char(2)
  codigoIbge          String?   @map("codigo_ibge") @db.VarChar(20)
  codigoUfIbge        String?   @map("codigo_uf_ibge") @db.VarChar(2)

  // Contato
  email               String?   @db.VarChar(255)
  telefone            String?   @db.VarChar(20)
  whatsapp            String?   @db.VarChar(20)
  site                String?   @db.VarChar(255)
  contatoFinanceiro   String?   @map("contato_financeiro") @db.VarChar(255)
  contatoFiscal       String?   @map("contato_fiscal") @db.VarChar(255)

  // Observações e fonte
  observacoes         String?   @db.Text
  fonteDados          String?   @map("fonte_dados") @db.VarChar(100)

  // Dados cadastrais estendidos
  porte               String?   @db.VarChar(60)
  capitalSocial       String?   @map("capital_social") @db.VarChar(40)
  dataAbertura        DateTime? @map("data_abertura")
  situacaoMotivo      String?   @map("situacao_motivo") @db.VarChar(200)
  optanteSimples      Boolean?  @map("optante_simples")
  mei                 Boolean?  @db.Boolean
  empresaPublica      Boolean?  @map("empresa_publica") @db.Boolean
  filial              Boolean?  @db.Boolean
  matriz              Boolean?  @db.Boolean

  // Dados tributários estendidos
  crt                 String?   @db.VarChar(2)
  indicadorIe         String?   @map("indicador_ie") @db.VarChar(2)
  ieStatus            String?   @map("ie_status") @db.VarChar(40)
  imStatus            String?   @map("im_status") @db.VarChar(40)
  tipoContribuinte    String?   @map("tipo_contribuinte") @db.VarChar(60)
  contribuinteIcms    Boolean?  @map("contribuinte_icms") @db.Boolean
  contribuinteIss     Boolean?  @map("contribuinte_iss") @db.Boolean
  substituicaoTributaria Boolean? @map("substituicao_tributaria") @db.Boolean
  retencoes           Json?     @db.Json

  // CNAEs
  cnaeSecundarios     Json?     @map("cnae_secundarios") @db.Json
  riscoFiscalCnae     String?   @map("risco_fiscal_cnae") @db.VarChar(20)
  atividadesPermitidas Json?    @map("atividades_permitidas") @db.Json
  atividadesIncompativeis Json? @map("atividades_incompativeis") @db.Json

  // Endereço estendido
  pais                String?   @db.VarChar(80)
  latitude            Float?    
  longitude           Float?    

  // FiscalAI
  fiscalAi            Json?     @map("fiscal_ai") @db.Json
  scoreCadastro       Int?      @map("score_cadastro") @db.SmallInt
  scoreDetalhes       Json?     @map("score_detalhes") @db.Json

  // Preparação reforma tributária
  reformaPrep         Json?     @map("reforma_prep") @db.Json

  // Dados de auditoria
  dadosOriginaisJson  Json?     @map("dados_originais_json")
  alertasJson         Json?     @map("alertas_json")
  validadoPorIa       Boolean   @default(false) @map("validado_por_ia")
  historicoJson       Json?     @map("historico_json") @db.Json
  ultimaConsulta      DateTime? @map("ultima_consulta")

  // Timestamps
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relação com User
  owner               User      @relation(fields: [ownerId], references: [id])

  // Índices para melhor performance
  @@index([ownerId])
  @@index([cpf])
  @@index([cnpj])
  @@index([tipoPessoa])
  @@map("clients")
}

model Product {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  name         String   @db.VarChar(255)
  code         String   @db.VarChar(80)
  ncm          String?  @db.VarChar(20)
  cest         String?  @db.VarChar(20)
  unit         String   @default("UN") @db.VarChar(10)
  price        Decimal  @default(0) @db.Decimal(15, 2)
  stock        Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, active])
  @@map("products")
}
