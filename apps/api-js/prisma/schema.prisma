model AccountantDocumentRequest {
  id                  String   @id @default(uuid()) @db.Uuid
  officeId            String   @map("office_id") @db.Uuid
  companyId           String   @map("company_id") @db.Uuid
  fiscalDocumentId    String?  @map("fiscal_document_id") @db.Uuid
  transportDocumentId String?  @map("transport_document_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
